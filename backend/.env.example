# Copy to .env and fill in values. Never commit .env.

# Neon: Dashboard → Connection string → use the "pooled" host for serverless apps.
# For async SQLAlchemy + asyncpg, use this scheme (replace postgresql:// with postgresql+asyncpg://):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?ssl=require
#
# If your Neon string includes channel_binding=require and asyncpg errors, try removing that param.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.ap-southeast-2.aws.neon.tech/neondb?ssl=require

# Same URL but postgresql+psycopg:// for Alembic migrations (sync), or run:
#   python -c "import os; print(os.environ['DATABASE_URL'].replace('+asyncpg','+psycopg'))"
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@ep-xxx-pooler.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# Comma-separated origins for CORS (annotation UI)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:5500

# Optional API root path (reverse proxy)
ROOT_PATH=

# JWT secret for auth tokens — MUST change in production
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# Inference provider: "openrouter" (default), "huggingface", "nvidia", or "custom"
# INFERENCE_PROVIDER=openrouter
# INFERENCE_ENABLED=true
# INFERENCE_REQUIRE_AUTH=false
# INFERENCE_MAX_TOKENS=1024
# INFERENCE_TIMEOUT_SECONDS=120

# Hugging Face Inference Providers (OpenAI-compatible router). Use a fine-grained token with
# "Make calls to Inference Providers" — see https://huggingface.co/settings/tokens
# HF_API_TOKEN=hf_...
# Alias also supported: HF_TOKEN or HUGGINGFACE_HUB_TOKEN
# HF_ROUTER_BASE_URL=https://router.huggingface.co/v1
# HF_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# NVIDIA NIM (OpenAI-compatible). Get an NGC API key at https://build.nvidia.com/settings/api-key
# NVIDIA_API_TOKEN=nvapi-...
# Alias also supported: NVIDIA_API_KEY or NGC_API_KEY
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_DEFAULT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# OpenRouter (OpenAI-compatible gateway — access NVIDIA, Meta, Google, etc. via one API key)
# Get an API key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_DEFAULT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Custom OpenAI-compatible provider (any endpoint supporting /v1/chat/completions)
# CUSTOM_API_TOKEN=sk-...
# CUSTOM_BASE_URL=https://your-provider.example.com/v1
# CUSTOM_DEFAULT_MODEL=your-org/your-model

# Gemini — used for LLM-as-Judge exam auto-review
# Get an API key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# AgentMail — email notifications via rlhf@agentmail.to
# Get an API key at https://console.agentmail.to/
# AGENTMAIL_API_KEY=am_...
# AGENTMAIL_INBOX_ID=<inbox-uuid from agentmail>
# AGENTMAIL_ENABLED=true
