# Repo root — used by docker-compose for the `api` service.
# Copy to .env and fill in. Never commit .env.

# Neon (use pooled host). Must use asyncpg driver for the app:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?ssl=require

# Optional: comma-separated browser origins (cross-origin only). Same-origin Docker UI usually ignores CORS.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Host port mapped to nginx (default 8080)
HTTP_PORT=8080
