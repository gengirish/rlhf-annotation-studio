{
  "name": "rlhf-annotation-studio",
  "private": true,
  "description": "Monorepo: Next.js frontend + FastAPI backend for RLHF Annotation Studio",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:e2e": "npm --prefix frontend run test:e2e",
    "vercel-build": "npm --prefix frontend run build",
    "backend:test": "cd backend && python -m pytest -q",
    "frontend:test": "npm --prefix frontend run test",
    "test:all": "npm run backend:test && npm run frontend:test && npm run frontend:e2e",
    "sync-fly-url": "node scripts/sync-vercel-fly-rewrite.mjs"
  },
  "dependencies": {
    "next": "^14.2.26"
  }
}
